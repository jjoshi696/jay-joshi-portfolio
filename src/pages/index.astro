---
import Layout from "@layouts/Layout.astro";
import Navbar from "@components/Navbar.astro";
import Hero from "@components/Hero.astro";
import About from "@components/About.astro";
import ImpactMetrics from "@components/ImpactMetrics.astro";
import ExpertiseCards from "@components/ExpertiseCards.astro";
import ExperienceTimeline from "@components/ExperienceTimeline.astro";
import TechStack from "@components/TechStack.astro";
import Education from "@components/Education.astro";
import ResumeDownload from "@components/ResumeDownload.astro";
import Contact from "@components/Contact.astro";
import Footer from "@components/Footer.astro";
---

<Layout>
  <Navbar />
  <main id="main" class="relative">
    <Hero />

    <div class="divider container-page mt-12"></div>

    <About />

    <div class="divider container-page"></div>

    <ImpactMetrics />

    <div class="divider container-page"></div>

    <ExpertiseCards />

    <div class="divider container-page"></div>

    <ExperienceTimeline />

    <div class="divider container-page"></div>

    <TechStack />

    <div class="divider container-page"></div>

    <Education />

    <div class="divider container-page"></div>

    <ResumeDownload />

    <div class="divider container-page"></div>

    <Contact />
  </main>
  <Footer />
</Layout>
