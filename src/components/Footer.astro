---
import { site, navItems } from "@data/site";
const year = new Date().getFullYear();
---

<footer class="relative border-t border-white/[0.06] py-12">
  <div class="container-page">
    <div class="flex flex-col gap-8 lg:flex-row lg:items-start lg:justify-between">
      <div class="max-w-md">
        <div class="flex items-center gap-3">
          <span
            class="grid h-9 w-9 place-items-center rounded-lg bg-gradient-to-br from-accent-cyan/30 via-accent-blue/20 to-accent-violet/30 text-sm font-bold tracking-tight text-white ring-1 ring-inset ring-white/10"
            >JJ</span
          >
          <div>
            <div class="text-sm font-semibold text-white">{site.name}</div>
            <div class="text-[10px] uppercase tracking-[0.18em] text-slate-400">
              Engineering Leader · AI · Cybersecurity
            </div>
          </div>
        </div>
        <p class="mt-4 text-sm text-slate-400">
          Executive technology portfolio focused on AI-driven SecOps, Managed
          XDR, and global engineering leadership.
        </p>
      </div>

      <div class="grid grid-cols-2 gap-10 sm:grid-cols-3">
        <div>
          <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
            Navigate
          </div>
          <ul class="mt-3 space-y-2 text-sm">
            {
              navItems.map((n) => (
                <li>
                  <a
                    href={n.href}
                    class="text-slate-300 transition-colors hover:text-white"
                  >
                    {n.label}
                  </a>
                </li>
              ))
            }
          </ul>
        </div>
        <div>
          <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
            Resources
          </div>
          <ul class="mt-3 space-y-2 text-sm">
            <li>
              <a
                href={site.resumeFile}
                download
                class="text-slate-300 transition-colors hover:text-white"
                >Download Resume</a
              >
            </li>
            <li>
              <a
                href="#experience"
                class="text-slate-300 transition-colors hover:text-white"
                >Experience</a
              >
            </li>
            <li>
              <a
                href="#tech"
                class="text-slate-300 transition-colors hover:text-white"
                >Tech Stack</a
              >
            </li>
          </ul>
        </div>
        <div>
          <div class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">
            Connect
          </div>
          <ul class="mt-3 space-y-2 text-sm">
            <li>
              <a
                href={`mailto:${site.email}`}
                class="text-slate-300 transition-colors hover:text-white"
                >Email</a
              >
            </li>
            <li>
              <a
                href={site.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="text-slate-300 transition-colors hover:text-white"
                >LinkedIn</a
              >
            </li>
          </ul>
        </div>
      </div>
    </div>

    <div class="mt-10 flex flex-col items-start justify-between gap-3 border-t border-white/[0.06] pt-6 text-xs text-slate-500 sm:flex-row sm:items-center">
      <div>© {year} {site.name}. All rights reserved.</div>
      <div>Engineering Leadership · AI · Cybersecurity</div>
    </div>
  </div>
</footer>
