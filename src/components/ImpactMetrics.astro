---
import { impactMetrics } from "@data/site";
---

<section id="impact" class="relative section-pad">
  <div class="container-page">
    <div class="max-w-2xl">
      <span class="eyebrow">Impact</span>
      <h2 class="heading-lg mt-4">
        Measurable outcomes across <span class="text-gradient"
          >automation, scale, and security</span
        >.
      </h2>
      <p class="mt-4 text-slate-400">
        Quantifiable results from leading engineering teams, building managed
        services, and driving AI-powered security transformation.
      </p>
    </div>

    <div class="mt-12 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
      {
        impactMetrics.map((m, i) => (
          <div class="card card-hover group">
            <div class="flex items-start justify-between">
              <span class="text-[10px] font-mono uppercase tracking-[0.18em] text-slate-500">
                0{i + 1}
              </span>
              <span class="inline-flex h-7 w-7 items-center justify-center rounded-full border border-accent-cyan/25 bg-accent-cyan/[0.06] text-accent-cyan transition-transform group-hover:scale-110">
                <svg
                  class="h-3.5 w-3.5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                >
                  <polyline points="23 6 13.5 15.5 8.5 10.5 1 18" />
                  <polyline points="17 6 23 6 23 12" />
                </svg>
              </span>
            </div>

            <div class="mt-6 text-3xl font-semibold tracking-tight text-white sm:text-[2rem]">
              <span class="text-gradient">{m.metric}</span>
            </div>
            <div class="mt-1 text-sm font-medium text-slate-200">{m.label}</div>
            <p class="mt-3 text-sm leading-relaxed text-slate-400">
              {m.description}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
