---
import { site } from "@data/site";
// NOTE: Email and LinkedIn values come from src/data/site.ts.
// Replace the placeholders there before deploying.
---

<section id="contact" class="section-pad">
  <div class="container-page">
    <div class="grid gap-10 lg:grid-cols-12 lg:gap-14">
      <div class="lg:col-span-6">
        <span class="eyebrow">Contact</span>
        <h2 class="heading-lg mt-4">
          Let's <span class="text-gradient">connect</span>.
        </h2>
        <p class="mt-5 max-w-xl text-slate-300">
          Open to conversations around AI-driven cybersecurity automation,
          Managed XDR, SOC transformation, engineering leadership, and digital
          transformation.
        </p>

        <div class="mt-8 flex flex-wrap gap-3">
          <a href={`mailto:${site.email}`} class="btn-primary">
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            Email Me
          </a>
          <a
            href={site.linkedin}
            target="_blank"
            rel="noopener noreferrer"
            class="btn-secondary"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="currentColor"
              aria-hidden="true"
            >
              <path
                d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.05-1.86-3.05-1.86 0-2.14 1.45-2.14 2.95v5.67H9.35V9h3.41v1.56h.05c.47-.9 1.63-1.86 3.36-1.86 3.6 0 4.27 2.37 4.27 5.45v6.3zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"
              ></path>
            </svg>
            LinkedIn
          </a>
          <a href={site.resumeFile} download class="btn-ghost">
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
              <polyline points="7 10 12 15 17 10"></polyline>
              <line x1="12" y1="15" x2="12" y2="3"></line>
            </svg>
            Download Resume
          </a>
        </div>
      </div>

      <div class="lg:col-span-6">
        <div class="card">
          <div class="grid grid-cols-1 gap-5 sm:grid-cols-2">
            <div>
              <div class="text-xs uppercase tracking-[0.18em] text-slate-500">
                Email
              </div>
              <a
                href={`mailto:${site.email}`}
                class="mt-1.5 block break-words text-sm text-white hover:text-accent-cyan"
              >
                {site.email}
              </a>
            </div>
            <div>
              <div class="text-xs uppercase tracking-[0.18em] text-slate-500">
                LinkedIn
              </div>
              <a
                href={site.linkedin}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-1.5 block break-words text-sm text-white hover:text-accent-cyan"
              >
                {site.linkedin.replace(/^https?:\/\//, "")}
              </a>
            </div>
            <div class="sm:col-span-2">
              <div class="text-xs uppercase tracking-[0.18em] text-slate-500">
                Location
              </div>
              <div class="mt-1.5 text-sm text-white">{site.location}</div>
            </div>
          </div>

          <div class="divider my-6"></div>

          <p class="text-xs text-slate-500">
            For partnership or speaking opportunities, please include company,
            scope, and timing in your message.
          </p>
        </div>
      </div>
    </div>
  </div>
</section>
